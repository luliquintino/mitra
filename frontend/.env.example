# MITRA Frontend Environment Configuration
# Copy this file to .env.local and update with your values

# ─── API Configuration ──────────────────────────────────────────────────────
# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# HTTP request timeout in milliseconds (default: 4000ms = 4 seconds)
NEXT_PUBLIC_API_TIMEOUT=4000

# ─── Notification Configuration ──────────────────────────────────────────────
# Polling interval for fetching new notifications in milliseconds
# (default: 30000ms = 30 seconds)
# How often the frontend checks for new notifications
NEXT_PUBLIC_NOTIFICATION_POLLING_INTERVAL=30000

# Toast message auto-dismiss duration in milliseconds
# (default: 5000ms = 5 seconds)
# How long toast notifications stay visible before disappearing
NEXT_PUBLIC_TOAST_DURATION=5000

# Confirmation message display duration in milliseconds
# (default: 4000ms = 4 seconds)
# How long confirmation messages (like "Perfil atualizado") are visible
NEXT_PUBLIC_CONFIRMATION_DURATION=4000

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Enable mock API fallback when backend is unavailable
# Set to 'true' to always use mock data (useful for offline development)
NEXT_PUBLIC_USE_MOCK=false

# Enable logging of API calls (useful for debugging)
NEXT_PUBLIC_LOG_API_CALLS=false

# ─── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development
