# ─────────────────────────────────────────────
# MITRA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_STAGE=beta

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mitra_db?schema=public"

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_EXPIRATION=15m

# Refresh Token
JWT_REFRESH_SECRET=seu_refresh_secret_super_seguro_aqui
JWT_REFRESH_EXPIRATION=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# Storage (S3 — mock inicial)
STORAGE_DRIVER=local
S3_BUCKET=mitra-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
